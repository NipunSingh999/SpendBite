<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_zinc_50">

    <!-- Hero Background Animation Layer (Blobs) -->
    <View
        android:id="@+id/bg_blob_primary"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_marginTop="-80dp"
        android:layout_marginEnd="-80dp"
        android:background="@drawable/bg_blur_primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/bg_blob_secondary"
        android:layout_width="360dp"
        android:layout_height="360dp"
        android:layout_marginStart="-120dp"
        android:layout_marginBottom="-120dp"
        android:background="@drawable/bg_blur_secondary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Main Container Scroll -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Branding Header -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/logo_brand" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="sans-serif-condensed"
                    android:text="@string/app_name"
                    android:textColor="@color/brand_primary"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Master your financial bite."
                    android:textColor="@color/text_zinc_500"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Glass Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="24dp"
                android:elevation="4dp">

                <TextView
                    android:id="@+id/tv_login_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome back"
                    android:textColor="@color/text_zinc_900"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_login_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="20dp"
                    android:text="Enter your credentials to access your dashboard"
                    android:textColor="@color/text_zinc_500"
                    android:textSize="13sp" />

                <!-- Email Form Field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email Address"
                    android:textColor="@color/text_zinc_500"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="4dp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/input_underlined_bg"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/iv_mail_icon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="14dp"
                        android:src="@drawable/ic_profile"
                        app:tint="@color/text_zinc_400" />

                    <EditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_toEndOf="@id/iv_mail_icon"
                        android:background="@null"
                        android:hint="name@company.com"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="12dp"
                        android:textColor="@color/text_zinc_900"
                        android:textSize="14sp" />
                </RelativeLayout>

                <!-- Password Form Field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textColor="@color/text_zinc_500"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="4dp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/input_underlined_bg"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:id="@+id/iv_lock_icon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="14dp"
                        android:src="@drawable/ic_lock"
                        app:tint="@color/text_zinc_400" />

                    <EditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_toStartOf="@+id/btn_toggle_password"
                        android:layout_toEndOf="@id/iv_lock_icon"
                        android:background="@null"
                        android:hint="••••••••"
                        android:inputType="textPassword"
                        android:paddingHorizontal="12dp"
                        android:textColor="@color/text_zinc_900"
                        android:textSize="14sp" />

                    <ImageView
                        android:id="@+id/btn_toggle_password"
                        android:layout_width="36dp"
                        android:layout_height="match_parent"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="8dp"
                        android:scaleType="center"
                        android:src="@android:drawable/ic_menu_view"
                        app:tint="@color/text_zinc_400"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/tv_error_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:textColor="@color/red_error"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <!-- Submit Button -->
                <Button
                    android:id="@+id/btn_authenticate"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/button_accent_bg"
                    android:fontFamily="sans-serif-medium"
                    android:text="Login"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_arrow_forward"
                    app:iconTint="@color/white"
                    app:iconGravity="textEnd" />

                <!-- Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/text_zinc_300" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        android:text="or continue with"
                        android:textColor="@color/text_zinc_400"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/text_zinc_300" />
                </LinearLayout>

                <!-- Google Auth Button -->
                <Button
                    android:id="@+id/btn_google_auth"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/button_outline_bg"
                    android:fontFamily="sans-serif-medium"
                    android:text="Sign in with Google"
                    android:textAllCaps="false"
                    android:textColor="@color/text_zinc_900"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_google"
                    app:iconTint="@null"
                    app:iconGravity="textStart" />


            </LinearLayout>

            <!-- Footer Links -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/btn_forgot_password"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Forgot Password?"
                    android:textColor="@color/brand_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_footer_prompt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Don't have an account? "
                        android:textColor="@color/text_zinc_500"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_footer_action"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Create Account"
                        android:textColor="@color/brand_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- Spacer bottom -->
            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Decorative Bottom Detail Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#1A000666" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#33000666" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#66000666" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#B3000666" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@color/brand_primary" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@color/brand_secondary" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
