<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/card_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Month Header Row -->
    <RelativeLayout
        android:id="@+id/rl_month_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/tv_history_month_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="July 2026"
            android:textColor="@color/text_zinc_900"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_history_month_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹12,450.00"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:id="@+id/iv_history_month_chevron"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/arrow_down_float"
                app:tint="@color/text_zinc_400" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Expandable Nested Transactions List Container -->
    <LinearLayout
        android:id="@+id/ll_expanded_transactions_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="10dp"
            android:background="@color/light_gray" />

        <!-- Constrained height with nested scrolling enabled to scroll internally in card -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_month_transactions"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:nestedScrollingEnabled="true"
            tools:listitem="@layout/item_transaction" />
    </LinearLayout>

</LinearLayout>
