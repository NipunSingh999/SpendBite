<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Top Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/text_zinc_300" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-condensed"
        android:text="Assemble SplitBite Group"
        android:textColor="@color/text_zinc_900"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Group Name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Group Name"
        android:textColor="@color/text_zinc_500"
        android:textSize="12sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/et_group_dialog_name"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/button_outline_bg"
        android:hint="E.g., Roommates 402, Goa Trip"
        android:inputType="text"
        android:paddingHorizontal="12dp"
        android:textColor="@color/text_zinc_900"
        android:textSize="14sp" />

    <!-- Description -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Description"
        android:textColor="@color/text_zinc_500"
        android:textSize="12sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/et_group_dialog_desc"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/button_outline_bg"
        android:hint="E.g., Shared dinner and grocery expenses"
        android:inputType="text"
        android:paddingHorizontal="12dp"
        android:textColor="@color/text_zinc_900"
        android:textSize="14sp" />

    <!-- Icon & Members -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category Icon"
                android:textColor="@color/text_zinc_500"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/sp_group_dialog_icon"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/button_outline_bg"
                android:padding="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Members (Initials, CSV)"
                android:textColor="@color/text_zinc_500"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_group_dialog_members"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/button_outline_bg"
                android:hint="E.g., AM, MR, JD"
                android:inputType="text"
                android:paddingHorizontal="12dp"
                android:textColor="@color/text_zinc_900"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_group_dialog_cancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/button_outline_bg"
            android:text="Discard"
            android:textAllCaps="false"
            android:textColor="@color/text_zinc_900"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btn_group_dialog_save"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/button_emerald_bg"
            android:text="Assemble Group"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@null" />
    </LinearLayout>

</LinearLayout>
