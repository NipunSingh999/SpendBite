<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app_res="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_zinc_50"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app_res:layout_constraintBottom_toBottomOf="parent"
        app_res:layout_constraintEnd_toEndOf="parent"
        app_res:layout_constraintStart_toStartOf="parent"
        app_res:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-condensed"
            android:text="Onboarding Center"
            android:textColor="@color/text_zinc_900"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Configure your food &amp; dining budget limits"
            android:textColor="@color/text_zinc_500"
            android:textSize="14sp" />

        <!-- Form Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Total Limit -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Monthly Budget (₹)"
                android:textColor="@color/text_zinc_900"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_onboard_total"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/button_outline_bg"
                android:inputType="numberDecimal"
                android:paddingHorizontal="12dp"
                android:text="15000"
                android:textColor="@color/text_zinc_900"
                android:textSize="14sp" />

            <!-- Meals Limit -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Meals &amp; Delivery Limit (₹)"
                android:textColor="@color/text_zinc_900"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_onboard_meals"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/button_outline_bg"
                android:inputType="numberDecimal"
                android:paddingHorizontal="12dp"
                android:text="5000"
                android:textColor="@color/text_zinc_900"
                android:textSize="14sp" />

            <!-- Groceries Limit -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Grocery Shopping Limit (₹)"
                android:textColor="@color/text_zinc_900"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_onboard_groceries"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/button_outline_bg"
                android:inputType="numberDecimal"
                android:paddingHorizontal="12dp"
                android:text="4000"
                android:textColor="@color/text_zinc_900"
                android:textSize="14sp" />

            <!-- Breach Alerts Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Enable Breach Alerts"
                    android:textColor="@color/text_zinc_900"
                    android:textSize="14sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_onboard_alerts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/btn_complete_onboarding"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/button_accent_bg"
            android:fontFamily="sans-serif-medium"
            android:text="Create Account &amp; Seed Data"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app_res:backgroundTint="@null" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
