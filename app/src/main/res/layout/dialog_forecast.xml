<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_card"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Header Drag Bar indicator -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="@color/text_zinc_300"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Spending Projections"
        android:textColor="@color/brand_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-condensed" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="20dp"
        android:text="Detailed analysis of your monthly culinary ledger forecasts."
        android:textColor="@color/text_zinc_500"
        android:textSize="13sp" />

    <!-- Details Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/button_outline_bg"
        android:backgroundTint="@color/surface_container_low"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DAILY AVERAGE SPEND"
                android:textColor="@color/text_zinc_500"
                android:textSize="11sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_forecast_daily_avg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:fontFamily="monospace"
                android:text="₹1,428"
                android:textColor="@color/text_zinc_900"
                android:textSize="13sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/light_gray"
            android:layout_marginVertical="12dp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PROJECTED MONTHLY TOTAL"
                android:textColor="@color/text_zinc_500"
                android:textSize="11sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_forecast_projected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:fontFamily="monospace"
                android:text="₹52,400"
                android:textColor="@color/brand_primary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/light_gray"
            android:layout_marginVertical="12dp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MONTHLY LIMIT CEILING"
                android:textColor="@color/text_zinc_500"
                android:textSize="11sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_forecast_limit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:fontFamily="monospace"
                android:text="₹55,000"
                android:textColor="@color/text_zinc_900"
                android:textSize="13sp"
                android:textStyle="bold" />
        </RelativeLayout>
    </LinearLayout>

    <!-- Forecast Alert Status view -->
    <LinearLayout
        android:id="@+id/ll_forecast_status_badge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/badge_caution_bg"
        android:backgroundTint="@color/icon_tint_grocery_bg"
        android:orientation="horizontal"
        android:padding="12dp"
        android:layout_marginBottom="20dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_forecast_status_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_dialog_info"
            app:tint="@color/emerald_success" />

        <TextView
            android:id="@+id/tv_forecast_status_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="On Track: Safe spending forecasted."
            android:textColor="@color/emerald_success"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_forecast_explanation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_zinc_500"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.2"
        android:layout_marginBottom="24dp"
        android:text="Your spending habits this month indicate you are well within limits. Keep tracking your dining and grocery bills to prevent sudden spikes." />

    <!-- Dismiss Button -->
    <Button
        android:id="@+id/btn_forecast_close"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/button_accent_bg"
        android:text="Dismiss Analysis"
        android:textAllCaps="false"
        android:textColor="@color/white"
        app:backgroundTint="@null" />

</LinearLayout>
